# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DB_NAME=focusai
DB_USER=focususer
DB_PASSWORD=focuspass
DB_HOST=localhost
DB_PORT=5432

# AI Engine (Optional - works without it)
OPENAI_API_KEY=your-openai-api-key-here

# Hugging Face API (Alternative to OpenAI)
HF_API_KEY=your-huggingface-api-key-here

# AI Provider Selection (openai or huggingface)
AI_PROVIDER=huggingface
