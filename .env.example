# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=False

# Database (Render will auto-provide DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# AI Provider Configuration
AI_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here
HF_API_KEY=your-huggingface-api-key-here

# For local development, use SQLite (no DATABASE_URL needed)
# The app will automatically use SQLite if DATABASE_URL is not set
